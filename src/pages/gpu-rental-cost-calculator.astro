---
import Layout from '~/layouts/PageLayout.astro';
import CostCalculator from '~/components/CostCalculator.astro';

const metadata = {
  title: 'GPU Rental Cost Calculator — Estimate Cloud GPU Cost per Hour',
  description:
    'Estimate the cost of renting a cloud GPU. Enter the $/hour rate and number of hours to get the total — for RunPod, Vast.ai, Lambda and any GPU cloud.',
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:px-6 mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight">How much does renting a GPU cost?</h1>
    <p class="mt-4 text-lg text-muted">
      The cost of a cloud GPU is simply its hourly rate multiplied by how long you run it: <strong>total = $/hour × hours</strong>.
      For example, an H100 at $2.99/hour for 100 hours costs $299. Use the calculator below to estimate your own.
    </p>

    <div class="mt-8">
      <CostCalculator />
    </div>

    <div class="mt-8 text-muted space-y-3">
      <p>
        Rates vary widely by provider and billing model. Spot and community instances are cheaper than on-demand or
        reserved, but less reliable. Compare live rates on the
        <a href="/gpu-cloud-prices" class="underline">GPU cloud price comparison</a> page.
      </p>
      <p class="text-sm">
        This estimate covers compute time only. Storage, egress and idle time may add to your bill.
      </p>
    </div>
  </section>
</Layout>
