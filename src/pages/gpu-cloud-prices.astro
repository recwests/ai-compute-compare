---
import Layout from '~/layouts/PageLayout.astro';
import PriceTable from '~/components/PriceTable.astro';
import { loadPrices } from '~/data/loadPrices';

const prices = loadPrices();
const cheapest = [...prices].sort((a, b) => a.pricePerHourUsd - b.pricePerHourUsd)[0];

const metadata = {
  title: 'Cheapest GPU Cloud Prices — Live Comparison (RunPod, Vast.ai, Lambda)',
  description:
    'Live $/hour price comparison for H100, A100 and RTX 4090 across RunPod, Vast.ai and Lambda. Find the cheapest GPU cloud for AI training and inference.',
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Dataset',
  name: 'GPU Cloud Price Comparison',
  description: 'Live $/hour prices for H100, A100 and RTX 4090 across RunPod, Vast.ai and Lambda.',
  dateModified: prices[0]?.updatedAt,
  creator: { '@type': 'Organization', name: 'AI Compute Compare' },
};
---

<Layout metadata={metadata}>
  <section class="px-4 py-12 sm:px-6 mx-auto max-w-4xl">
    <h1 class="text-3xl md:text-4xl font-bold tracking-tight">What is the cheapest GPU cloud right now?</h1>
    <p class="mt-4 text-lg text-muted">
      As of {cheapest.updatedAt}, the cheapest listed option is <strong>{cheapest.provider}</strong> at
      <strong>${cheapest.pricePerHourUsd.toFixed(2)}/hour</strong> for a {cheapest.gpu}. The table below compares live
      on-demand $/hour prices across RunPod, Vast.ai and Lambda, updated daily.
    </p>

    <div class="mt-8">
      <PriceTable />
    </div>

    <p class="mt-6 text-sm text-muted">
      Prices are listed on-demand rates and change frequently. Each row links to the provider. We may earn a commission
      from these links.
    </p>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
</Layout>
