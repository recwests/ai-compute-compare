---
// Island: the only client-side JS on the site. Text/answer lives in the page (raw HTML for crawlers).
---

<div class="border border-gray-200 dark:border-slate-700 rounded-lg p-6 max-w-md">
  <div class="flex flex-col gap-4">
    <label class="flex items-center justify-between gap-4">
      <span>GPU price ($/hour)</span>
      <input
        id="cc-price"
        type="number"
        value="2.99"
        step="0.01"
        min="0"
        class="w-28 rounded border border-gray-300 dark:border-slate-600 bg-transparent px-2 py-1 text-right tabular-nums"
      />
    </label>
    <label class="flex items-center justify-between gap-4">
      <span>Hours</span>
      <input
        id="cc-hours"
        type="number"
        value="100"
        min="0"
        class="w-28 rounded border border-gray-300 dark:border-slate-600 bg-transparent px-2 py-1 text-right tabular-nums"
      />
    </label>
    <p class="text-lg font-semibold border-t border-gray-200 dark:border-slate-700 pt-3">
      Total: $<span id="cc-out" class="tabular-nums">299.00</span>
    </p>
  </div>
</div>

<script>
  const calc = () => {
    const price = parseFloat((document.getElementById('cc-price') as HTMLInputElement).value) || 0;
    const hours = parseFloat((document.getElementById('cc-hours') as HTMLInputElement).value) || 0;
    const total = Math.round(Math.max(0, price) * Math.max(0, hours) * 100) / 100;
    (document.getElementById('cc-out') as HTMLElement).textContent = total.toFixed(2);
  };
  document.getElementById('cc-price')?.addEventListener('input', calc);
  document.getElementById('cc-hours')?.addEventListener('input', calc);
</script>
