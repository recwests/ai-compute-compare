---
import { loadPrices } from '~/data/loadPrices';

const rows = [...loadPrices()].sort((a, b) => a.pricePerHourUsd - b.pricePerHourUsd);
---

<div class="overflow-x-auto">
  <table class="w-full text-left border-collapse">
    <thead>
      <tr class="border-b-2 border-gray-300 dark:border-slate-600">
        <th class="py-2 pr-4">Provider</th>
        <th class="py-2 pr-4">GPU</th>
        <th class="py-2 pr-4">$ / hour</th>
        <th class="py-2 pr-4">Billing</th>
        <th class="py-2 pr-4"></th>
      </tr>
    </thead>
    <tbody>
      {
        rows.map((r) => (
          <tr class="border-b border-gray-200 dark:border-slate-700">
            <td class="py-2 pr-4 font-medium">{r.provider}</td>
            <td class="py-2 pr-4">{r.gpu}</td>
            <td class="py-2 pr-4 tabular-nums">${r.pricePerHourUsd.toFixed(2)}</td>
            <td class="py-2 pr-4 text-sm opacity-80">{r.billing}</td>
            <td class="py-2 pr-4">
              <a
                href={r.affiliateUrl}
                rel="sponsored nofollow"
                target="_blank"
                class="text-primary underline whitespace-nowrap"
              >
                View →
              </a>
            </td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>
